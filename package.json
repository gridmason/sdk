{
  "name": "@gridmason/sdk",
  "version": "0.0.0",
  "description": "Gridmason host-SDK interface + widget-side helper library: the capability-scoped chokepoint a host implements and a widget author imports. All widget I/O flows through it.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/helpers/react/index.d.ts",
      "import": "./dist/helpers/react/index.js"
    },
    "./vue": {
      "types": "./dist/helpers/vue/index.d.ts",
      "import": "./dist/helpers/vue/index.js"
    },
    "./vanilla": {
      "types": "./dist/helpers/vanilla/index.d.ts",
      "import": "./dist/helpers/vanilla/index.js"
    },
    "./noop": {
      "types": "./dist/noop/index.d.ts",
      "import": "./dist/noop/index.js"
    },
    "./fixture": {
      "types": "./dist/fixture/index.d.ts",
      "import": "./dist/fixture/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance/index.d.ts",
      "import": "./dist/conformance/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "10.0.1",
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
